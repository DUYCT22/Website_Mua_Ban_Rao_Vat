@model Website_Mua_Ban_Rao_Vat.Models.User
@{
    ViewBag.Title = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Đăng nhập</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <style>
        body {
            background-color:moccasin;
        }
        input.form-control {
            padding-right: 2.5rem;
        }
    </style>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var form = document.querySelector('form');

            form.addEventListener('submit', function (event) {
                event.preventDefault();

                var formData = new FormData(form);

                fetch(form.action, {
                    method: 'POST',
                    body: formData
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({
                                position: "top-end",
                                text: data.message,
                                icon: "success",
                                showConfirmButton: false,
                                timer: 1500
                            }).then(() => {
                                window.opener.location.href = data.redirectUrl;
                                window.close();
                            });
                        } else {
                            Swal.fire({
                                position: "top-end",
                                text: data.message,
                                icon: "error",
                                showConfirmButton: true
                            });
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        Swal.fire({
                            position: "top-end",
                            text: "Có lỗi xảy ra. Vui lòng thử lại sau.",
                            icon: "error",
                            showConfirmButton: true
                        });
                    });
            });
        });
    </script>
</head>
<body>
    <div class="container py-5">
        <img class="img-fluid" src="~/Contents/image/Logo.png" />
        <h2 class="text-center mb-4">Đăng nhập</h2>

        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow p-4">
                    @using (Html.BeginForm("Index", "Account", FormMethod.Post))
                    {
                        <div class="form-group mb-3">
                            <h6>Tên đăng nhập</h6>
                            @Html.TextBoxFor(m => m.LoginName, new { @class = "form-control", placeholder = "vd: duyot" })
                        </div>

                        <div class="form-group mb-3">
                            <h6>Mật khẩu</h6>
                            <div class="position-relative">
                                @Html.PasswordFor(m => m.Password, new { @class = "form-control pe-5", id = "passwordInput", placeholder = "Nhập mật khẩu" })
                                <span class="position-absolute top-50 end-0 translate-middle-y me-3" style="cursor:pointer;" id="togglePassword">
                                    <i class="fa fa-eye" id="toggleIcon"></i>
                                </span>
                            </div>

                        </div>

                        <button type="submit" class="btn btn-primary w-100">Đăng nhập</button>
                    }

                    <hr class="my-4" />

                    <div class="d-grid gap-2">
                        <a href="@Url.Action("ExternalLogin", "Account", new { provider = "Facebook" })" class="btn btn-outline-primary">
                            <i class="fab fa-facebook me-2"></i> Đăng nhập với Facebook
                        </a>

                        <a href="@Url.Action("ExternalLogin", "Account", new { provider = "Google" })" class="btn btn-outline-danger">
                            <i class="fab fa-google me-2"></i> Đăng nhập với Google
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const toggle = document.getElementById('togglePassword');
            const input = document.getElementById('passwordInput');
            const icon = document.getElementById('toggleIcon');

            toggle.addEventListener('click', function () {
                const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
                input.setAttribute('type', type);
                icon.classList.toggle('fa-eye');
                icon.classList.toggle('fa-eye-slash');
            });
        });
    </script>


</body>
</html>
